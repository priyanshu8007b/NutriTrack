rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PAUSHTIKPATH SECURITY RULES PHILOSOPHY
     * 
     * Core Philosophy: 
     * This ruleset implements a strict path-based ownership model combined with role-based access 
     * control (RBAC) via a dedicated admin collection. All user-specific data is isolated 
     * within the user's own document tree.
     * 
     * Data Structure:
     * - /userProfiles/{userId}: Root for user identity.
     * - /userProfiles/{userId}/mealLogs/{mealLogId}: User-specific private meal history.
     * - /userProfiles/{userId}/userGoal/{goalId}: User-specific nutritional targets (singleton).
     * - /foodItems/{foodItemId}: Global public catalog of nutritional data.
     * - /roles_admin/{uid}: Internal collection to designate administrative users.
     */

    // --- Global Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the user is designated as an administrator in the DBAC collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Users manage their own identity.
     */
    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      // Simplified: Ownership is determined by the path parameter matching the auth UID.
      allow create, update, delete: if isOwner(userId);

      /**
       * @description Rules for a user's private meal logs.
       */
      match /mealLogs/{mealLogId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }

      /**
       * @description Rules for a user's nutritional goals (subcollection singleton).
       * @path /userProfiles/{userId}/userGoal/{goalId}
       */
      match /userGoal/{goalId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }

    /**
     * @description Global master list of food items and their macros.
     */
    match /foodItems/{foodItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Administrative roles collection (DBAC).
     */
    match /roles_admin/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}